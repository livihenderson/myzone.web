# Public canonical site URL — used to build absolute logo + link URLs in emails.
SITE_URL=https://myzonegym.cz

# SMTP transport (server-only) — webglobe defaults shown.
SMTP_HOST=mail.webglobe.cz
SMTP_PORT=587
# SMTP_SECURE: "tls" => secure: true (typically port 465).
#              "starttls" => secure: false + requireTLS: true (typically port 587).
SMTP_SECURE=starttls
SMTP_USER=noreply@myzonegym.cz
SMTP_PASSWORD=

# Sender identity — submitter email goes in Reply-To, never in From.
EMAIL_FROM=noreply@myzonegym.cz
EMAIL_FROM_NAME=MyZone

# Owner notification recipients — comma-separated, no spaces required.
CONTACT_EMAIL_TO=bfbc2bylpz@gmail.com,olivia.praha01@gmail.com

# reCAPTCHA v3.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Float between 0 and 1. Lower = more permissive. 0.5 is Google's default.
RECAPTCHA_SCORE_THRESHOLD=0.5
# Comma-separated allow-list checked against the reCAPTCHA `hostname` field.
# Defaults to the host of SITE_URL plus localhost when unset.
RECAPTCHA_ALLOWED_HOSTS=myzonegym.cz,localhost
